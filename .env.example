# Backend Environment Variables
# Never commit your actual .env file to version control
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=8000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/node-rest-shop

# JWT Configuration
# Generate a strong secret key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=your_very_secret_key_at_least_32_characters_long

# File Upload Configuration
BASE_URL=http://localhost:8000

# Production Settings (uncomment when deploying to production)
# NODE_ENV=production
# PORT=443
# CLIENT_URL=https://yourdomain.com
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database
# BASE_URL=https://yourdomain.com
